{
  "tasks": {
    "jt": "deno run --allow-read --allow-write --allow-env --allow-net src/main.ts",
    "test": "deno test --allow-read --allow-write --allow-env --allow-net",
    "check": "deno check src/main.ts && deno lint",
    "install": "deno install --global --force --name jt --allow-read --allow-write --allow-env --allow-net --config deno.json src/main.ts"
  },
  "imports": {
    "@std/cli": "jsr:@std/cli@^1.0.0",
    "@std/path": "jsr:@std/path@^1.0.0",
    "@std/assert": "jsr:@std/assert@^1.0.0",
    "zod": "npm:zod@^4.0.0",
    "marked": "npm:marked@^15.0.0"
  },
  "fmt": {
    "lineWidth": 100
  }
}
